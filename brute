#!/bin/bash

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Version
VERSION="1.0"

# Function to display banner
function show_banner {
    echo -e "${BLUE}"
    echo "╔════════════════════════════════════════════════════════╗"
    echo "║           Hydra Easy - Security Testing Tool          ║"
    echo "║                    Version $VERSION                     ║"
    echo "╚════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# Help function
function show_help {
    show_banner
    echo -e "${YELLOW}Usage:${NC} ./hydra_easy.sh [OPTIONS]"
    echo ""
    echo -e "${YELLOW}Options:${NC}"
    echo "  -u, --url URL              Target URL (e.g., https://example.com)"
    echo "  -U, --username USER        Username or username list file"
    echo "  -P, --password FILE        Password list file"
    echo "  -s, --service SERVICE      Service type (ssh, ftp, http, https, mysql, etc.)"
    echo "  -p, --port PORT            Custom port number"
    echo "  -f, --form-params PARAMS   HTTP form parameters for login"
    echo "  -t, --threads THREADS      Number of threads (default: 16)"
    echo "  -T, --timeout TIMEOUT      Timeout in seconds (default: 30)"
    echo "  -o, --output FILE          Output file for results"
    echo "  -v, --verbose              Verbose output"
    echo "  -h, --help                 Show this help message"
    echo ""
    echo -e "${YELLOW}Examples:${NC}"
    echo "  # SSH brute force"
    echo "  ./hydra_easy.sh -u admin -P passwords.txt -s ssh -t 192.168.1.1"
    echo ""
    echo "  # HTTP form login"
    echo "  ./hydra_easy.sh -u users.txt -P passwords.txt -s https \\"
    echo "    -f \"/login.php:username=^USER^&password=^PASS^:F=error\" \\"
    echo "    -t https://example.com"
    echo ""
    echo "  # FTP with custom port"
    echo "  ./hydra_easy.sh -u admin -P passwords.txt -s ftp -p 2121 -t 10.0.0.1"
    echo ""
    echo -e "${RED}IMPORTANT:${NC} Only use this tool on systems you own or have written permission to test!"
    exit 1
}

# Check if hydra is installed
function check_hydra {
    if ! command -v hydra &> /dev/null; then
        echo -e "${RED}Error: Hydra is not installed!${NC}"
        echo "Install it with: sudo apt-get install hydra (Debian/Ubuntu)"
        echo "Or: sudo yum install hydra (RHEL/CentOS)"
        exit 1
    fi
}

# Validate URL/IP
function validate_target {
    if [[ $1 =~ ^https?:// ]]; then
        # Extract IP/hostname from URL
        target_ip=$(echo "$1" | sed 's|.*://||' | cut -d':' -f1 | cut -d'/' -f1)
        protocol=$(echo "$1" | cut -d':' -f1)
    else
        # Assume it's an IP
        target_ip=$1
        protocol=${service:-ssh}
    fi
    
    # Validate IP format
    if [[ ! $target_ip =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]] && \
       [[ ! $target_ip =~ ^[a-zA-Z0-9.-]+$ ]]; then
        echo -e "${RED}Error: Invalid target IP/hostname: $target_ip${NC}"
        exit 1
    fi
}

# Parse command line arguments
username=""
password_file=""
target=""
service=""
port=""
form_params=""
threads=16
timeout=30
output_file=""
verbose=0

# If no arguments, show help
if [ $# -eq 0 ]; then
    show_help
fi

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -u|--username)
            username="$2"
            shift 2
            ;;
        -P|--password)
            password_file="$2"
            shift 2
            ;;
        -s|--service)
            service="$2"
            shift 2
            ;;
        -p|--port)
            port="$2"
            shift 2
            ;;
        -f|--form-params)
            form_params="$2"
            shift 2
            ;;
        -t|--threads)
            threads="$2"
            shift 2
            ;;
        -T|--timeout)
            timeout="$2"
            shift 2
            ;;
        -o|--output)
            output_file="$2"
            shift 2
            ;;
        -v|--verbose)
            verbose=1
            shift
            ;;
        -h|--help)
            show_help
            ;;
        -*)
            echo -e "${RED}Error: Unknown option $1${NC}"
            show_help
            ;;
        *)
            target="$1"
            shift
            ;;
    esac
done

# Check for required tools
check_hydra

# Validate target
if [ -z "$target" ]; then
    echo -e "${RED}Error: Target URL/IP is required!${NC}"
    show_help
fi

validate_target "$target"

# Check if password file exists
if [ -z "$password_file" ]; then
    echo -e "${RED}Error: Password file is required!${NC}"
    show_help
fi

if [ ! -f "$password_file" ]; then
    echo -e "${RED}Error: Password file '$password_file' not found!${NC}"
    exit 1
fi

# Check if username file exists or use single username
if [ -f "$username" ]; then
    username_opt="-L \"$username\""
    username_type="file"
elif [ -n "$username" ]; then
    username_opt="-l \"$username\""
    username_type="single"
else
    echo -e "${RED}Error: Username or username file is required!${NC}"
    show_help
fi

# Determine service
if [ -z "$service" ] && [ -n "$protocol" ]; then
    case $protocol in
        http)
            service="http-get"
            ;;
        https)
            service="https-get"
            ;;
        *)
            service="ssh"
            ;;
    esac
elif [ -z "$service" ]; then
    service="ssh"
fi

# Handle HTTP/HTTPS form parameters
if [[ "$service" == *"post-form"* ]] || [ -n "$form_params" ]; then
    if [ -n "$form_params" ]; then
        if [[ "$service" == "https"* ]]; then
            service="https-post-form \"$form_params\""
        else
            service="http-post-form \"$form_params\""
        fi
    else
        echo -e "${YELLOW}Warning: HTTP form parameters not provided! Using GET method.${NC}"
    fi
fi

# Build hydra command
hydra_cmd="hydra"
hydra_cmd+=" -t $threads"
hydra_cmd+=" -w $timeout"
hydra_cmd+=" $username_opt"
hydra_cmd+=" -P \"$password_file\""

if [ -n "$port" ]; then
    hydra_cmd+=" -s $port"
fi

if [ -n "$output_file" ]; then
    hydra_cmd+=" -o \"$output_file\""
fi

if [ $verbose -eq 1 ]; then
    hydra_cmd+=" -V"
fi

hydra_cmd+=" $target_ip $service"

# Display configuration
show_banner
echo -e "${GREEN}Configuration:${NC}"
echo "  Target: $target_ip"
echo "  Protocol: ${protocol:-$service}"
echo "  Port: ${port:-default}"
echo "  Username: ${username:-from file}"
echo "  Password file: $password_file"
echo "  Service: $service"
echo "  Threads: $threads"
echo "  Timeout: $timeout seconds"
[ -n "$output_file" ] && echo "  Output: $output_file"
echo ""

# Warning and confirmation
echo -e "${RED}╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${RED}║  WARNING: Only use this on systems you own or have      ║${NC}"
echo -e "${RED}║  explicit written permission to test!                   ║${NC}"
echo -e "${RED}║  Unauthorized access is illegal and unethical!          ║${NC}"
echo -e "${RED}╚══════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${YELLOW}Press Enter to start attack or Ctrl+C to cancel...${NC}"
read -r

# Run the attack
echo -e "${GREEN}Starting attack...${NC}"
echo ""

eval "$hydra_cmd"

# Display results
echo ""
echo -e "${GREEN}Attack completed!${NC}"

if [ -n "$output_file" ] && [ -f "$output_file" ]; then
    echo -e "${GREEN}Results saved to: $output_file${NC}"
fi
